[property]
gpu-id=0
net-scale-factor=0.00392156862745098
model-color-format=0
# ONNX model exported from CFD YOLOv12x via DeepStream-Yolo export script
onnx-file=cfd-yolov12x-1.00.onnx
# model-engine-file is auto-generated by DeepStream based on batch-size/gpu/precision
# e.g. model_b6_gpu0_fp32.engine for 6-stream, model_b1_gpu0_fp32.engine for single-video
labelfile-path=cfd_labels.txt
batch-size=6
network-mode=0
num-detected-classes=1
interval=3
gie-unique-id=1
process-mode=1
network-type=0
cluster-mode=2
# YOLOv12 uses center-padding (letterbox) — must preserve aspect ratio
maintain-aspect-ratio=1
symmetric-padding=1
# Input resolution: 640px for performance on GTX 1080 Ti
# Re-export at 1024px and update infer-dims if accuracy is insufficient
infer-dims=3;640;640
# Updated parser from DeepStream-Yolo (supports YOLOv12 output format)
parse-bbox-func-name=NvDsInferParseYolo
custom-lib-path=libnvdsinfer_custom_impl_Yolo_cfd.so

[class-attrs-all]
nms-iou-threshold=0.45
pre-cluster-threshold=0.25
topk=300
